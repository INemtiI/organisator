rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'rodionovazarij@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organizer')
      ); 
    }

    function isParticipant() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'participant';
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Data Validation ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName', 'email', 'role', 'createdAt']) 
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 255
        && data.role in ['participant', 'organizer']
        && data.createdAt is timestamp
        && (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1000));
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'startTime', 'endTime'])
        && data.title is string && data.title.size() <= 200
        && data.startTime is timestamp
        && data.endTime is timestamp
        && (!data.keys().contains('type') || data.type in ['session', 'masterclass', 'break', 'other'])
        && (!data.keys().contains('maxParticipants') || data.maxParticipants is int)
        && (!data.keys().contains('confirmedCount') || data.confirmedCount is int);
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['userId', 'eventId', 'status', 'timestamp'])
        && data.userId is string
        && data.status in ['confirmed', 'waitlist']
        && isValidId(data.eventId)
        && data.timestamp is timestamp;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'userName', 'text', 'timestamp', 'channelId', 'userRole'])
        && data.userId == request.auth.uid
        && data.text is string && data.text.size() <= 1000
        && data.timestamp == request.time
        && data.channelId in ['general', 'secret', 'event']
        && data.userRole in ['participant', 'organizer']
        && (data.channelId != 'secret' || data.userRole == 'participant')
        && (data.channelId != 'event' || (data.keys().contains('eventId') && isValidId(data.eventId)))
        && (!data.keys().contains('reactions') || data.reactions is map);
    }

    function isValidQuestion(data) {
      return data.keys().hasAll(['userId', 'userName', 'userPhoto', 'text', 'timestamp', 'status'])
        && data.keys().size() == 6
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 200
        && data.userPhoto is string && data.userPhoto.size() <= 2000
        && data.text is string && data.text.size() <= 2000
        && data.timestamp == request.time
        && data.status == 'pending';
    }

    // --- Rules ---

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin(); 
    }

    match /test/connection {
      allow get: if true; // Allow connectivity check
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) 
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']) && incoming().updatedAt == request.time)
        );
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow delete, create: if isAdmin();
      // Allow update for admins OR specific confirmedCount updates
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['confirmedCount']));
    }

    match /registrations/{registrationId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /chat_messages/{messageId} {
      allow list: if isSignedIn() && (
        resource.data.channelId == 'general' || 
        (resource.data.channelId == 'secret' && isParticipant()) ||
        (resource.data.channelId == 'event' && (
          isAdmin() || 
          (resource.data.keys().contains('eventId') && 
           exists(/databases/$(database)/documents/registrations/$(request.auth.uid + "_" + resource.data.eventId)))
        ))
      );
      allow get: if isSignedIn() && (
        resource.data.channelId == 'general' || 
        (resource.data.channelId == 'secret' && isParticipant()) ||
        (resource.data.channelId == 'event' && (
          isAdmin() || 
          (resource.data.keys().contains('eventId') && 
           exists(/databases/$(database)/documents/registrations/$(request.auth.uid + "_" + resource.data.eventId)))
        ))
      );
      allow create: if isSignedIn() && isValidChatMessage(incoming()) && (
        incoming().channelId != 'event' || 
        isAdmin() || 
        exists(/databases/$(database)/documents/registrations/$(request.auth.uid + "_" + incoming().eventId))
      );
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['reactions']) && incoming().reactions is map;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /questions/{questionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidQuestion(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && (
          // Allow users to upvote if we keep that feature (votes field was in old blueprint)
          incoming().diff(existing()).affectedKeys().hasOnly(['votes'])
        )
      );
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /votes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && (incoming().timestamp == request.time || incoming().timestamp is timestamp);
      allow update, delete: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
